# ============================================================
# Supabase Docker — Windows Server
# Kopiraj u: C:\supabase\docker\.env
# (posle: copy .env.example .env pa zameni ove delove)
# ============================================================

############
# OBAVEZNO — promeni pre go-live
############
POSTGRES_PASSWORD=ZAMENI_jaka_lozinka_min_32_znaka
JWT_SECRET=ZAMENI_openssl_rand_base64_32
SECRET_KEY_BASE=ZAMENI_openssl_rand_base64_32
VAULT_ENC_KEY=ZAMENI_32_hex_znaka

############
# Javni URL — kako browser u fabrici zove API
############
# PREPORUČENO: Nginx/IIS proxy na 443, API kroz isti domen
SITE_URL=https://spc.firma.local
API_EXTERNAL_URL=https://spc.firma.local
SUPABASE_PUBLIC_URL=https://spc.firma.local

# PRIVREMENO (samo test, bez proxy-ja):
# SITE_URL=http://192.168.10.50:8000
# API_EXTERNAL_URL=http://192.168.10.50:8000
# SUPABASE_PUBLIC_URL=http://192.168.10.50:8000

############
# Portovi (default Supabase docker)
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
POSTGRES_PORT=5432
STUDIO_PORT=8000

############
# Ključevi — generišu se posle prvog `docker compose up`
# ANON_KEY ide u VITE_SUPABASE_ANON_KEY (build frontenda)
# SERVICE_ROLE_KEY — SAMO DOBAVLJAČ, ne IT
############
# ANON_KEY=eyJ...
# SERVICE_ROLE_KEY=eyJ...

############
# Email (opciono — inače Auth samo sa ručno kreiranim korisnicima)
############
# SMTP_ADMIN_EMAIL=admin@fabrika.local
# SMTP_HOST=
# SMTP_PORT=587

############
# Windows / Docker Desktop
############
# Ako Studio ne radi, proveri da WSL2 ima dovoljno RAM-a (min 8 GB za ceo stack)

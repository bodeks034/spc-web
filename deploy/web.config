<?xml version="1.0" encoding="UTF-8"?>
<!--
  SPC Web — IIS (URL Rewrite + ARR reverse proxy ka Supabase Kong :8000)

  Kopija u folder sajta zajedno sa build-om:
    C:\inetpub\spc-web\dist\web.config

  Preduslovi:
    - IIS URL Rewrite Module 2.1
    - Application Request Routing (ARR) 3.0 — Server Proxy enabled
    - HTTPS binding na sajtu (tableti / kamera)
    - Supabase Docker na http://127.0.0.1:8000

  Build frontenda:
    VITE_SUPABASE_URL=https://spc.firma.local
    (isti host kao ovaj IIS sajt — API ide kroz proxy ispod)

  Uputstvo: deploy/IIS_SETUP_WINDOWS.md
-->
<configuration>
  <system.webServer>

  <!-- Upload crteža / Excel sync do ~50 MB -->
  <security>
    <requestFiltering>
      <requestLimits maxAllowedContentLength="52428800" />
    </requestFiltering>
  </security>

  <rewrite>
    <rules>

      <!-- ── Supabase API (pre SPA fallback-a) ── -->

      <rule name="SPC_Proxy_Auth" stopProcessing="true">
        <match url="^auth/v1(.*)" />
        <action type="Rewrite" url="http://127.0.0.1:8000/auth/v1{R:1}" />
        <serverVariables>
          <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
        </serverVariables>
      </rule>

      <rule name="SPC_Proxy_Rest" stopProcessing="true">
        <match url="^rest/v1(.*)" />
        <action type="Rewrite" url="http://127.0.0.1:8000/rest/v1{R:1}" />
        <serverVariables>
          <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
        </serverVariables>
      </rule>

      <rule name="SPC_Proxy_Storage" stopProcessing="true">
        <match url="^storage/v1(.*)" />
        <action type="Rewrite" url="http://127.0.0.1:8000/storage/v1{R:1}" />
        <serverVariables>
          <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
        </serverVariables>
      </rule>

      <rule name="SPC_Proxy_Realtime" stopProcessing="true">
        <match url="^realtime/v1(.*)" />
        <action type="Rewrite" url="http://127.0.0.1:8000/realtime/v1{R:1}" />
        <serverVariables>
          <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
        </serverVariables>
      </rule>

      <rule name="SPC_Proxy_Functions" stopProcessing="true">
        <match url="^functions/v1(.*)" />
        <action type="Rewrite" url="http://127.0.0.1:8000/functions/v1{R:1}" />
        <serverVariables>
          <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
        </serverVariables>
      </rule>

      <!-- ── React SPA — statički fajl ili index.html ── -->

      <rule name="SPC_SPA_Fallback" stopProcessing="true">
        <match url=".*" />
        <conditions logicalGrouping="MatchAll">
          <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          <add input="{REQUEST_URI}" pattern="^/(auth|rest|storage|realtime|functions)/v1" negate="true" />
        </conditions>
        <action type="Rewrite" url="/index.html" />
      </rule>

    </rules>

    <!-- Dozvoli serverVariables iz pravila (ARR) -->
    <allowedServerVariables>
      <add name="HTTP_X_FORWARDED_PROTO" />
      <add name="HTTP_X_FORWARDED_HOST" />
    </allowedServerVariables>
  </rewrite>

  <!-- Keš statike (opciono) -->
  <staticContent>
    <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
  </staticContent>

  <httpProtocol>
    <customHeaders>
      <remove name="X-Powered-By" />
    </customHeaders>
  </httpProtocol>

  <!-- WebSocket za Realtime (IIS 8+) -->
  <webSocket enabled="true" />

  </system.webServer>
</configuration>

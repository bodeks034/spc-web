# ============================================================
# SAMO ZA FIRMINSKI SERVER — ne za cloud Supabase
# ============================================================
# VAŽNO: Kopiraj u KOREN projekta kao:
#   C:\mix\spc-web\.env.production   (pre npm run build)
# Za lokalni dev (npm run dev) koristi:
#   C:\mix\spc-web\.env.local
# Vite NE čita fajlove iz deploy/ foldera!
# Linije moraju biti BEZ # na početku.
# URL i anon key uzmi sa TOG servera (supabase/docker/.env), NE sa supabase.co
#
# Ako program i baza rade isključivo u fabrici — ovo je OBAVEZNO.
# Cloud podrazumevane vrednosti u kodu se NE koriste posle ovog build-a.

# --- Varijanta A: Nginx proxy (preporučeno) ---
# API ide kroz isti domen — vidi deploy/nginx-spc.conf.example
VITE_SUPABASE_URL=https://spc.firma.local
VITE_SUPABASE_ANON_KEY=<anon_key_iz_supabase_docker_env>

# Licenca — u produkciji NE stavljaj VITE_LICENCA_ISKLJUCENA
# VITE_LICENCA_ISKLJUCENA=1   ← samo za lokalni dev bez 21_licenca_gate.sql

# --- Brending (login + Admin → O programu) ---
# Logo: public/logo-firme.png ili VITE_LOGO_URL=...
# VITE_NAZIV_FIRME=Fabrika XY d.o.o.
# VITE_NAZIV_APLIKACIJE=SPC Kontrola kvaliteta
# VITE_RAZVOJ_NAZIV=Vaša firma / studio
# VITE_RAZVOJ_AUTOR=Ime Prezime
# VITE_RAZVOJ_EMAIL=podrska@example.com
# VITE_RAZVOJ_TEL=+381 ...
# VITE_RAZVOJ_KONTAKT=opciono jedan red umesto email+tel

# --- Varijanta B: direktan port Supabase-a ---
# VITE_SUPABASE_URL=https://spc.firma.local:8000
# VITE_SUPABASE_ANON_KEY=<anon_key>

# Skripte na serveru (backup) — NE ugrađuju se u frontend
# SUPABASE_URL=http://127.0.0.1:8000
# SUPABASE_SERVICE_ROLE_KEY=<service_role_tajno>

# Docker frontend na Windows — deploy/.env.docker
# docker compose -f docker-compose.spc.yml --env-file .env.docker up -d --build

# Browser otvara kontejner na 8080; unutra nginx proxy ka Supabase na hostu
VITE_SUPABASE_URL=http://localhost:8080
VITE_SUPABASE_ANON_KEY=ZAMENI_anon_key_iz_supabase_docker_env
SPC_HTTP_PORT=8080

# Supabase Kong mora slušati na host:8000 (docker compose u C:\supabase\docker)

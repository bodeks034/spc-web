# ============================================================
# SPC frontend build — Windows on-prem
# Kopiraj u KOREN projekta: C:\mix\spc-web\.env.production
# Zatim: npm run build
# ============================================================

############
# VARIJANTA A — Nginx/IIS proxy (PREPORUČENO)
# API: /auth/v1, /rest/v1, /storage/v1 na istom domenu
############
VITE_SUPABASE_URL=https://spc.firma.local
VITE_SUPABASE_ANON_KEY=ZAMENI_anon_key_iz_C_supabase_docker_env

############
# VARIJANTA B — direktan port Supabase (samo test)
############
# VITE_SUPABASE_URL=https://spc.firma.local:8000
# VITE_SUPABASE_ANON_KEY=ZAMENI_anon_key

############
# Licenca — u produkciji NE uključuj:
# VITE_LICENCA_ISKLJUCENA=1

############
# Brending (opciono)
############
# VITE_NAZIV_FIRME=Fabrika XY d.o.o.
# VITE_NAZIV_APLIKACIJE=SPC Kontrola kvaliteta

############
# SAMO za skripte na TVOM računaru — NE na serveru gde IT čita fajlove
# Koristi za: postavi-licencu.mjs, backup sa dev mašine
############
# SUPABASE_URL=https://spc.firma.local
# SUPABASE_SERVICE_ROLE_KEY=ZAMENI_service_role_SAMO_KOD_DOBAVLJACA

############
# Alternativa migracija sa dev računara (npm run db:migrate -- --all)
############
# DATABASE_URL=postgresql://postgres:LOZINKA@192.168.10.50:5432/postgres

{
  "verzija": 1,
  "erp_sistem": "pantheon",
  "opis": "Pantheon ERP — tipični nazivi kolona iz izvoza (Ident, Naziv, RN…)",
  "redosled_uvoza": [
    "linije",
    "masine",
    "smene",
    "tipovi_vozila",
    "pogon_linija_mapa",
    "delovi",
    "crtezi_dela",
    "greske_katalog",
    "kupci",
    "merila",
    "kalibracije",
    "karakteristike_merljive",
    "barkod_profili",
    "radnici",
    "radni_nalozi"
  ],
  "entiteti": {
    "linije": {
      "ukljuceno": true,
      "opis": "Proizvodne linije",
      "fajl": "linije.csv",
      "fajl_alternativni": ["pantheon_linije.csv", "proizvodne_linije.csv"],
      "tabela": "linije",
      "upsert_strategija": "name_lookup",
      "lookup_polje": "linija",
      "obavezna_polja": ["linija"],
      "kolone": {
        "linija": { "iz": ["Linija", "linija", "ProizvodnaLinija", "radno_mesto"] },
        "proces": { "iz": ["Proces", "proces", "OperacijaOpis"] },
        "operacija": { "iz": ["Operacija", "operacija", "Korak"] }
      }
    },
    "masine": {
      "ukljuceno": true,
      "opis": "Strojevi / mašine",
      "fajl": "masine.csv",
      "fajl_alternativni": ["pantheon_masine.csv", "strojevi.csv"],
      "tabela": "masine",
      "upsert_kljuc": "naziv",
      "obavezna_polja": ["naziv"],
      "kolone": {
        "naziv": { "iz": ["Stroj", "stroj", "Masina", "masina", "naziv", "OznakaStroja"] }
      }
    },
    "smene": {
      "ukljuceno": false,
      "fajl": "smene.csv",
      "fajl_alternativni": ["pantheon_smene.csv"],
      "tabela": "smene",
      "upsert_kljuc": "naziv",
      "obavezna_polja": ["naziv"],
      "kolone": {
        "naziv": { "iz": ["Smena", "smena", "naziv"] }
      }
    },
    "tipovi_vozila": {
      "ukljuceno": false,
      "opis": "Grupe artikala / modeli vozila",
      "fajl": "tipovi_vozila.csv",
      "fajl_alternativni": ["pantheon_vozila.csv", "grupe_artikala.csv"],
      "tabela": "tipovi_vozila",
      "upsert_kljuc": "kod",
      "obavezna_polja": ["kod", "naziv"],
      "podrazumevano": { "aktivan": true },
      "kolone": {
        "kod": { "iz": ["KodGrupe", "kod", "SifraGrupe", "GrupaArt"], "transform": "upper" },
        "naziv": { "iz": ["NazivGrupe", "naziv", "OpisGrupe"] },
        "prefiks_id_deo": { "iz": ["Prefiks", "prefiks_id_deo"] },
        "aktivan": { "iz": ["Aktivan", "aktivan"], "transform": "bool" },
        "napomena": { "iz": ["Napomena", "napomena"] }
      }
    },
    "delovi": {
      "ukljuceno": true,
      "opis": "Artikli / identi (šifarnik delova)",
      "fajl": "delovi.csv",
      "fajl_alternativni": ["pantheon_delovi.csv", "artikli.csv", "identi.csv"],
      "tabela": "delovi",
      "upsert_kljuc": "id_deo",
      "merge_nulls": true,
      "preserve_polja": ["karakteristika", "linija_id", "masina_id", "kom_za_kontrolu", "slika_naziv"],
      "obavezna_polja": ["id_deo", "naziv_dela"],
      "podrazumevano": { "aktivan": true, "tip_kontrole": "deo", "kom_za_kontrolu": 30 },
      "kolone": {
        "id_deo": { "iz": ["Ident", "ident", "Sifra", "sifra", "id_deo", "Artikal"], "transform": "upper" },
        "naziv_dela": { "iz": ["Naziv", "naziv", "NazivArtikla", "naziv_dela", "Opis"] },
        "pogon_kod": { "iz": ["Pogon", "pogon_kod", "Skladiste"], "transform": "upper" },
        "radni_nalog": { "iz": ["RadniNalog", "radni_nalog"] },
        "karakteristika": { "iz": ["Karakteristika", "karakteristika"] },
        "linija_id": { "iz": ["LinijaId", "linija_id"], "transform": "int" },
        "masina_id": { "iz": ["MasinaId", "masina_id"], "transform": "int" },
        "kom_za_kontrolu": { "iz": ["KomZaKontrolu", "kom_za_kontrolu"], "transform": "int" },
        "slika_naziv": { "iz": ["Crtez", "slika_naziv"] },
        "aktivan": { "iz": ["Aktivan", "aktivan"], "transform": "bool" },
        "napomena": { "iz": ["Napomena", "napomena"] },
        "tip_kontrole": { "iz": ["TipKontrole", "tip_kontrole"], "transform": "tip_kontrole" },
        "vozilo_katalog_id": { "iz": ["GrupaArt", "vozilo_katalog_id"] }
      }
    },
    "crtezi_dela": {
      "ukljuceno": true,
      "opis": "Crteži dela — Pantheon / PLM izvoz",
      "fajl": "crtezi_dela.csv",
      "fajl_alternativni": ["pantheon_crtezi.csv", "crtezi.csv"],
      "tabela": "crtez_assets",
      "upsert_strategija": "ref_lookup",
      "postavi_updated_at": true,
      "ref_tip_fiksno": "deo",
      "lookup_polja": ["ref_tip", "ref_id", "revizija"],
      "obavezna_polja": ["ref_id", "prikaz_putanja"],
      "podrazumevano": {
        "ref_tip": "deo",
        "prikaz_format": "svg",
        "revizija": "A",
        "aktivna": true
      },
      "kolone": {
        "ref_id": { "iz": ["Ident", "ident", "id_deo", "SifraArtikla"], "transform": "upper" },
        "ref_tip": { "iz": ["ref_tip", "TipRef"] },
        "naziv": { "iz": ["NazivCrteza", "naziv", "Crtez"] },
        "izvor_format": { "iz": ["FormatIzvor", "izvor_format"] },
        "izvor_putanja": { "iz": ["PutanjaDWG", "izvor_putanja"] },
        "prikaz_format": { "iz": ["FormatPrikaz", "prikaz_format"] },
        "prikaz_putanja": { "iz": ["PutanjaSVG", "prikaz_putanja", "PutanjaPrikaz"] },
        "revizija": { "iz": ["Revizija", "revizija", "Rev"] },
        "aktivna": { "iz": ["Aktivan", "aktivna"], "transform": "bool" },
        "napomena": { "iz": ["Napomena", "napomena"] }
      }
    },
    "kupci": {
      "ukljuceno": true,
      "opis": "Partneri — kupci",
      "fajl": "kupci.csv",
      "fajl_alternativni": ["pantheon_kupci.csv", "partneri.csv", "kupci_partneri.csv"],
      "tabela": "kupci",
      "upsert_kljuc": "naziv",
      "izbaci_polja": ["id"],
      "merge_nulls": true,
      "obavezna_polja": ["naziv"],
      "podrazumevano": { "aktivan": true },
      "kolone": {
        "id": { "iz": ["Id", "id", "SifraPartnera"], "transform": "int" },
        "naziv": { "iz": ["Naziv", "naziv", "NazivPartnera", "Kupac", "kupac"] },
        "aktivan": { "iz": ["Aktivan", "aktivan"], "transform": "bool" }
      }
    },
    "radnici": {
      "ukljuceno": false,
      "fajl": "radnici.csv",
      "fajl_alternativni": ["pantheon_radnici.csv", "zaposleni.csv"],
      "tabela": "radnici",
      "upsert_strategija": "email_lookup",
      "lookup_polje": "email",
      "fallback_lookup": "ime",
      "obavezna_polja": ["ime", "uloga"],
      "podrazumevano": { "uloga": "operator", "aktivan": true },
      "kolone": {
        "ime": { "iz": ["Ime", "ime", "Zaposleni", "ImePrezime", "name"] },
        "uloga": { "iz": ["Uloga", "uloga", "Pozicija"], "transform": "uloga" },
        "email": { "iz": ["Email", "email", "e_mail"] },
        "aktivan": { "iz": ["Aktivan", "aktivan"], "transform": "bool" },
        "napomena": { "iz": ["Sifra", "napomena"] }
      }
    },
    "radni_nalozi": {
      "ukljuceno": true,
      "opis": "Radni / proizvodni nalozi",
      "fajl": "radni_nalozi.csv",
      "fajl_alternativni": ["pantheon_radni_nalozi.csv", "proizvodni_nalozi.csv", "rn.csv"],
      "tabela": "radni_nalozi",
      "upsert_strategija": "legacy_radni_nalozi",
      "sync_kupci": true,
      "merge_nulls": true,
      "obavezna_polja": ["broj_naloga", "id_deo"],
      "podrazumevano": { "status": "aktivan" },
      "kolone": {
        "broj_naloga": { "iz": ["BrojRN", "broj_naloga", "RadniNalog", "RN", "rn", "Nalog"] },
        "id_deo": { "iz": ["Ident", "ident", "SifraArtikla", "id_deo", "Artikal"] },
        "pogon_kod": { "iz": ["Pogon", "pogon_kod"] },
        "naziv_dela": { "iz": ["NazivArtikla", "naziv_dela", "Naziv"] },
        "kolicina": { "iz": ["Kolicina", "kolicina", "PlaniranaKol"] },
        "kupac": { "iz": ["Kupac", "kupac", "NazivKupca", "Partner"] },
        "datum_unosa": { "iz": ["Datum", "datum_unosa", "DatumOtvaranja"] },
        "rok_isporuke": { "iz": ["Rok", "rok_isporuke", "DatumIsporuke"] },
        "status": { "iz": ["Status", "status", "StanjeRN"] },
        "operater": { "iz": ["Operater", "operater"] },
        "napomena": { "iz": ["Napomena", "napomena"] }
      }
    },
    "greske_katalog": {
      "ukljuceno": true,
      "opis": "Katalog defekata / šifarnik grešaka",
      "fajl": "greske_katalog.csv",
      "fajl_alternativni": ["pantheon_greske.csv", "defekti.csv", "sifarnik_gresaka.csv"],
      "tabela": "greske_katalog",
      "upsert_kljuc": "kategorija,podkategorija,defekt",
      "izbaci_polja": ["id"],
      "obavezna_polja": ["kategorija", "podkategorija"],
      "kolone": {
        "kategorija": { "iz": ["Kategorija", "kategorija", "Grupa"] },
        "podkategorija": { "iz": ["Podkategorija", "podkategorija", "SifraGreske"] },
        "defekt": { "iz": ["Defekt", "defekt", "Naziv"] },
        "opis": { "iz": ["Opis", "opis", "Napomena"] },
        "id_deo": { "iz": ["Ident", "id_deo", "SifraArtikla"], "transform": "upper" },
        "katalog_id": { "iz": ["KatalogId", "katalog_id"] },
        "pogon_kod": { "iz": ["Pogon", "pogon_kod"], "transform": "upper" }
      }
    },
    "merila": {
      "ukljuceno": true,
      "opis": "Merna oprema / instrumenti",
      "fajl": "merila.csv",
      "fajl_alternativni": ["pantheon_merila.csv", "instrumenti.csv", "alati.csv"],
      "tabela": "merila",
      "upsert_strategija": "merilo_lookup",
      "lookup_polje": "naziv",
      "merilo_serijski_polje": "serijski_broj",
      "obavezna_polja": ["naziv"],
      "podrazumevano": { "aktivno": true },
      "kolone": {
        "naziv": { "iz": ["Naziv", "naziv", "NazivMerila", "Instrument"] },
        "serijski_broj": { "iz": ["SerijskiBroj", "serijski_broj", "Serijski", "Inventarski"] },
        "tip": { "iz": ["Tip", "tip", "Vrsta"] },
        "lokacija": { "iz": ["Lokacija", "lokacija", "Mesto"] },
        "opseg": { "iz": ["Opseg", "opseg", "MerniOpseg"] },
        "aktivno": { "iz": ["Aktivno", "aktivno", "Aktivan"], "transform": "bool" }
      }
    },
    "kalibracije": {
      "ukljuceno": true,
      "opis": "Kalibracije merila",
      "fajl": "kalibracije.csv",
      "fajl_alternativni": ["pantheon_kalibracije.csv", "kalibracija.csv"],
      "tabela": "kalibracije",
      "upsert_strategija": "kalibracije_merilo",
      "lookup_polja": ["merilo_id", "datum_kal"],
      "merilo_serijski_iz": ["SerijskiBroj", "serijski_broj", "merilo_serijski"],
      "merilo_naziv_iz": ["NazivMerila", "merilo_naziv", "Instrument"],
      "obavezna_polja": ["datum_kal"],
      "izbaci_polja": ["id"],
      "kolone": {
        "datum_kal": { "iz": ["DatumKal", "datum_kal", "DatumKalibracije"], "transform": "datum" },
        "sledeca_kal": { "iz": ["SledecaKal", "sledeca_kal", "DatumIsteka"], "transform": "datum" },
        "izvrsio": { "iz": ["Izvrsio", "izvrsio", "Servis"] },
        "sertifikat_br": { "iz": ["Sertifikat", "sertifikat_br", "CertBr"] },
        "rezultat": { "iz": ["Rezultat", "rezultat"] },
        "napomena": { "iz": ["Napomena", "napomena"] }
      }
    },
    "karakteristike_merljive": {
      "ukljuceno": true,
      "opis": "Kontrolne dimenzije / granice po delu",
      "fajl": "karakteristike_merljive.csv",
      "fajl_alternativni": ["pantheon_dimenzije.csv", "dimenzije.csv", "kontrolne_tacke.csv"],
      "tabela": "karakteristike_merljive",
      "mapiranje": "karakteristike_merljive",
      "upsert_strategija": "karakteristike_merljive",
      "upsert_kljuc": "id_deo,pogon_kod,sifra_merenja,pozicija",
      "obavezna_polja": ["id_deo", "pozicija"],
      "kolone": {}
    },
    "barkod_profili": {
      "ukljuceno": false,
      "opis": "Profil barkod etikete po delu",
      "fajl": "barkod_profili.csv",
      "fajl_alternativni": ["pantheon_barkod.csv", "etikete.csv"],
      "tabela": "barkod_profili",
      "upsert_kljuc": "id_deo,format",
      "obavezna_polja": ["id_deo", "sadrzaj_barkoda"],
      "podrazumevano": { "format": "id_rn", "tip_koda": "oba", "aktivna": true },
      "kolone": {
        "id_deo": { "iz": ["Ident", "id_deo", "SifraArtikla"], "transform": "upper" },
        "format": { "iz": ["Format", "format"] },
        "sadrzaj_barkoda": { "iz": ["SadrzajBarkoda", "sadrzaj_barkoda", "Barkod"] },
        "radni_nalog": { "iz": ["BrojRN", "radni_nalog"], "transform": "upper" },
        "tip_koda": { "iz": ["TipKoda", "tip_koda"] },
        "aktivna": { "iz": ["Aktivna", "aktivna"], "transform": "bool" },
        "napomena": { "iz": ["Napomena", "napomena"] }
      }
    },
    "pogon_linija_mapa": {
      "ukljuceno": false,
      "opis": "Mapa linija faza → pogon",
      "fajl": "pogon_linija_mapa.csv",
      "fajl_alternativni": ["pantheon_pogon_mapa.csv"],
      "tabela": "pogon_linija_mapa",
      "upsert_kljuc": "linija_faza",
      "obavezna_polja": ["linija_faza", "pogon_kod"],
      "kolone": {
        "linija_faza": { "iz": ["LinijaFaza", "linija_faza", "Faza"] },
        "linija_id": { "iz": ["LinijaId", "linija_id"], "transform": "int" },
        "pogon_kod": { "iz": ["Pogon", "pogon_kod"], "transform": "upper" }
      }
    }
  }
}

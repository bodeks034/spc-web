# Kopiraj u .env.local i prilagodi vrednosti.
# Vite učitava samo promenljive koje počinju sa VITE_

# --- Cloud Supabase (podrazumevano u kodu) ---
# VITE_SUPABASE_URL=https://wzxkcomeurogvfisticq.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- Lokalni Supabase (supabase start) ---
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<anon key iz: supabase status>

# Skripte (import, backup) — NE stavljaj u frontend, samo za terminal
# SUPABASE_URL=https://wzxkcomeurogvfisticq.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role iz Dashboard → Settings → API>

# --- Automatski ERP uvoz (cron) — kopiraj u .env.erp ---
# ERP_DROP_DIR=erp-drop/incoming
# ERP_MIN_AGE_MIN=2

# --- SAP CSV → Excel šifrarnik — folder sap-drop/incoming ---
# SAP_DROP_DIR=sap-drop/incoming
# SAP_MASTER_XLSX=excel-rad/SPC_master_atributivne.xlsx

# --- Brending (login, početni ekran, Admin → O programu) ---
# Logo: stavi public/logo-firme.png ili:
# VITE_LOGO_URL=/putanja/do/logo.png
# VITE_LOGO_URL=none
# VITE_NAZIV_FIRME=Fabrika XY d.o.o.
# VITE_NAZIV_APLIKACIJE=SPC Kontrola kvaliteta
# VITE_RAZVOJ_NAZIV=Vaša firma razvoja
# VITE_RAZVOJ_AUTOR=Ime Prezime
# VITE_RAZVOJ_EMAIL=podrska@example.com
# VITE_RAZVOJ_TEL=+381 ...
# (kopiraj u .env.local u KORENU projekta — ne u deploy/)

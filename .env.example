# Kopiraj u .env.local i prilagodi vrednosti.
# Vite učitava samo promenljive koje počinju sa VITE_
# Terminal skripte (smoke-test, import) čitaju .env.local i .env

# --- Cloud Supabase (podrazumevano u kodu) ---
# VITE_SUPABASE_URL=https://wzxkcomeurogvfisticq.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- Lokalni Supabase (supabase start) ---
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<anon key iz: supabase status>

# --- E2E (Playwright) — opciono za CI / puni tok ---
# E2E_BASE_URL=http://127.0.0.1:5173
# E2E_EMAIL=operater@firma.com
# E2E_PASSWORD=...
# E2E_EMAIL_KVALITET=kvalitet@firma.com
# E2E_PASSWORD_KVALITET=...
# E2E_ID_DEO=MRAP-001

# --- Resend (npm run deploy:resend) — email alarmi u browseru (HTTP API) ---
# RESEND_API_KEY=re_...
# RESEND_FROM=SPC <onboarding@resend.dev>
#   (sandbox šalje samo na email Resend naloga; produkcija: docs/RESEND_PRODUKCIJA.md)
# RESEND_FROM=SPC <spc@firma.rs>

# --- SMTP deploy (npm run deploy:smtp) — IT mail server / Gmail iz Node skripti ---
# SUPABASE_PROJECT_REF=wzxkcomeurogvfisticq
# SMTP_HOST=smtp.firma.rs
# SMTP_PORT=587
# SMTP_USER=spc@firma.rs
# SMTP_PASS=...
# SMTP_FROM=SPC <spc@firma.rs>
# SMTP_TLS=1
# SMTP_TO=kvalitet@firma.rs
#   (podrazumevani primalac za npm run email:send bez --to)
# SUPABASE_URL=https://wzxkcomeurogvfisticq.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role iz Dashboard → Settings → API>
# DATABASE_URL=postgresql://postgres.[ref]:[PASS]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#   (za npm run db:migrate — Database → Connection string u Supabase Dashboard)

# --- Automatski ERP uvoz (cron) — kopiraj u .env.erp ---
# ERP_DROP_DIR=erp-drop/incoming
# ERP_MIN_AGE_MIN=2

# --- Vercel cron (cloud) — api/cron.js ---
# CRON_SECRET=<nasumičan string — Vercel → Settings → Environment Variables>

# --- On-prem cron podsetnici — opciono ---
# LICENSE_VAZI_DO=2027-12-31
# DIGEST_PO_LINIJI=1
# DIGEST_LINIJA=Ulazna kontrola
#   (podsetnik 30/7/1 dan pre isteka licence u auto-podsetnici.mjs)
# SPC_BACKUP_DIR=D:\Backup\spc
#   (nocni PostgreSQL backup — Windows Task Scheduler)
# SPC_DOCKER_DB=supabase-db
# SPC_BACKUP_KEEP_DAYS=30

# --- SAP CSV → Excel šifrarnik — folder sap-drop/incoming ---
# SAP_DROP_DIR=sap-drop/incoming
# SAP_MASTER_XLSX=excel-rad/SPC_master_atributivne.xlsx

# --- Brending (TRI-CORE QC — dominantan brend) ---
# Pun logo: public/tri-core-qc-logo.png · simbol: tri-core-qc-symbol.png
# VITE_NAZIV_APLIKACIJE=TRI-CORE QC
# VITE_SLOGAN=Tri modula. Jedan sistem kvaliteta.
# Klijent (fabrika) — samo O programu: VITE_NAZIV_FIRME=Fabrika XY d.o.o.
# Login gore: Developed by {firma} · login dole: Developed by {autor}
# VITE_RAZVOJ_NAZIV=Vaša firma d.o.o.
# VITE_RAZVOJ_AUTOR=Ime Prezime
# VITE_RAZVOJ_EMAIL=podrska@example.com
# VITE_RAZVOJ_TEL=+381 ...
# (kopiraj u .env.local u KORENU projekta — ne u deploy/)
